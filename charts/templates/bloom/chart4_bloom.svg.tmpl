<svg xmlns="http://www.w3.org/2000/svg" width="780" height="550" viewBox="0 0 780 550" font-family="-apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif">
  <rect width="780" height="550" fill="#ffffff"/>

  <!-- Hatch = the taskset-pinned single-core Hardwood bars (over the bar's own hue). -->
  <defs>
    <pattern id="onecore" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(45)">
      <line x1="0" y1="0" x2="0" y2="6" stroke="#1a1a1a" stroke-opacity="0.32" stroke-width="2.4"/>
    </pattern>
  </defs>

  <!-- Title -->
  <text x="40" y="30" font-size="20" font-weight="700" fill="#1a1a1a">Bloom-filter point lookup (equality push-down)</text>
  <text x="40" y="50" font-size="12.5" fill="#495057">Hardwood ↔ parquet-java · bloom-bearing file vs statistics-only twin · $bds</text>
  <text x="40" y="67" font-size="11" fill="#868e96">$machine, warm cache · $java</text>

  <!-- Legend: engine × bloom = colour; a hatch overlay marks the 1-core (pinned) Hardwood bars -->
  <rect x="40"  y="82" width="12" height="12" rx="2" fill="#1971c2"/>
  <text x="57"  y="92" font-size="11.5" fill="#495057">Hardwood · bloom</text>
  <rect x="175" y="82" width="12" height="12" rx="2" fill="#a5d8ff"/>
  <text x="192" y="92" font-size="11.5" fill="#495057">Hardwood · no bloom</text>
  <rect x="330" y="82" width="12" height="12" rx="2" fill="#f08c00"/>
  <text x="347" y="92" font-size="11.5" fill="#495057">parquet-java · bloom</text>
  <rect x="485" y="82" width="12" height="12" rx="2" fill="#ffd8a8"/>
  <text x="502" y="92" font-size="11.5" fill="#495057">parquet-java · no bloom</text>
  <rect x="650" y="82" width="12" height="12" rx="2" fill="#ced4da"/>
  <rect x="650" y="82" width="12" height="12" rx="2" fill="url(#onecore)"/>
  <text x="667" y="92" font-size="11.5" fill="#495057">1 core*</text>

  <!-- everything below the legend is shifted down for legend-to-plot whitespace -->
  <g transform="translate(0, 10)">
  <!-- Y axis title -->
  <text x="22" y="250" font-size="12.5" fill="#495057" transform="rotate(-90 22 250)" text-anchor="middle">time per lookup (ms · lower is better)</text>

  <!-- Gridlines + tick labels: linear 0..top, data-driven (make-bloom-chart.py chart4). -->
  <g stroke="#ececec" stroke-width="1">
    $gridlines
  </g>
  <g font-size="11" fill="#adb5bd" text-anchor="end">
    $ticklabels
  </g>
  <line x1="70" y1="400" x2="740" y2="400" stroke="#bbb" stroke-width="1.5"/>

  <!-- ===== PRESENT group (centre 237.5): HW bloom ±1core, HW no-bloom ±1core, PJ bloom, PJ no-bloom ===== -->
  <rect x="93.5"  y="$p_hwb_y"  width="40" height="$p_hwb_h"  rx="2" fill="#1971c2"/>
  <text x="113.5" y="$p_hwb_ly" font-size="11" font-weight="700" fill="#1971c2" text-anchor="middle">$p_hwb_v</text>
  <rect x="141.5" y="$p_hwb1_y" width="40" height="$p_hwb1_h" rx="2" fill="#1971c2"/>
  <rect x="141.5" y="$p_hwb1_y" width="40" height="$p_hwb1_h" rx="2" fill="url(#onecore)"/>
  <text x="161.5" y="$p_hwb1_ly" font-size="11" font-weight="700" fill="#1971c2" text-anchor="middle">$p_hwb1_v</text>
  <rect x="189.5" y="$p_hwn_y"  width="40" height="$p_hwn_h"  rx="2" fill="#a5d8ff"/>
  <text x="209.5" y="$p_hwn_ly" font-size="11" font-weight="700" fill="#1971c2" text-anchor="middle">$p_hwn_v</text>
  <rect x="237.5" y="$p_hwn1_y" width="40" height="$p_hwn1_h" rx="2" fill="#a5d8ff"/>
  <rect x="237.5" y="$p_hwn1_y" width="40" height="$p_hwn1_h" rx="2" fill="url(#onecore)"/>
  <text x="257.5" y="$p_hwn1_ly" font-size="11" font-weight="700" fill="#1971c2" text-anchor="middle">$p_hwn1_v</text>
  <rect x="293.5" y="$p_pjb_y"  width="40" height="$p_pjb_h"  rx="2" fill="#f08c00"/>
  <text x="313.5" y="$p_pjb_ly" font-size="11" font-weight="700" fill="#e8590c" text-anchor="middle">$p_pjb_v</text>
  <rect x="341.5" y="$p_pjn_y"  width="40" height="$p_pjn_h"  rx="2" fill="#ffd8a8"/>
  <text x="361.5" y="$p_pjn_ly" font-size="11" font-weight="700" fill="#e8590c" text-anchor="middle">$p_pjn_v</text>

  <!-- ===== ABSENT group (centre 572.5) ===== -->
  <rect x="428.5" y="$a_hwb_y"  width="40" height="$a_hwb_h"  rx="2" fill="#1971c2"/>
  <text x="448.5" y="$a_hwb_ly" font-size="11" font-weight="700" fill="#1971c2" text-anchor="middle">$a_hwb_v</text>
  <rect x="476.5" y="$a_hwb1_y" width="40" height="$a_hwb1_h" rx="2" fill="#1971c2"/>
  <rect x="476.5" y="$a_hwb1_y" width="40" height="$a_hwb1_h" rx="2" fill="url(#onecore)"/>
  <text x="496.5" y="$a_hwb1_ly" font-size="11" font-weight="700" fill="#1971c2" text-anchor="middle">$a_hwb1_v</text>
  <rect x="524.5" y="$a_hwn_y"  width="40" height="$a_hwn_h"  rx="2" fill="#a5d8ff"/>
  <text x="544.5" y="$a_hwn_ly" font-size="11" font-weight="700" fill="#1971c2" text-anchor="middle">$a_hwn_v</text>
  <rect x="572.5" y="$a_hwn1_y" width="40" height="$a_hwn1_h" rx="2" fill="#a5d8ff"/>
  <rect x="572.5" y="$a_hwn1_y" width="40" height="$a_hwn1_h" rx="2" fill="url(#onecore)"/>
  <text x="592.5" y="$a_hwn1_ly" font-size="11" font-weight="700" fill="#1971c2" text-anchor="middle">$a_hwn1_v</text>
  <rect x="628.5" y="$a_pjb_y"  width="40" height="$a_pjb_h"  rx="2" fill="#f08c00"/>
  <text x="648.5" y="$a_pjb_ly" font-size="11" font-weight="700" fill="#e8590c" text-anchor="middle">$a_pjb_v</text>
  <rect x="676.5" y="$a_pjn_y"  width="40" height="$a_pjn_h"  rx="2" fill="#ffd8a8"/>
  <text x="696.5" y="$a_pjn_ly" font-size="11" font-weight="700" fill="#e8590c" text-anchor="middle">$a_pjn_v</text>

  <!-- Group labels -->
  <text x="237.5" y="424" font-size="13.5" font-weight="700" fill="#1a1a1a" text-anchor="middle">PRESENT PROBE</text>
  <text x="237.5" y="440" font-size="11.5" fill="#868e96" text-anchor="middle">bloom keeps every row group · HW $p_hw_x×, PJ $p_pj_x×</text>
  <text x="572.5" y="424" font-size="13.5" font-weight="700" fill="#1a1a1a" text-anchor="middle">ABSENT PROBE</text>
  <text x="572.5" y="440" font-size="11.5" fill="#868e96" text-anchor="middle">bloom drops every row group · HW $a_hw_x×, PJ $a_pj_x×</text>

  <!-- group divider -->
  <line x1="405" y1="100" x2="405" y2="400" stroke="#f0f0f0" stroke-width="1"/>

  <!-- footnote -->
  <text x="40" y="478" font-size="11.5" fill="#868e96">No-bloom = the statistics-only twin (dictionary off), where nothing prunes and the whole column is scanned. N× = no-bloom ÷ bloom.</text>
  <text x="40" y="494" font-size="11.5" fill="#868e96">The present value is a common fare in every row group, so the bloom prunes nothing; the absent value is in none, so it drops them all.</text>
  <text x="40" y="510" font-size="11.5" fill="#868e96">* 1 core = taskset -c 0 (one SMT thread sharing a physical core); only Hardwood is re-timed pinned (parquet-java is single-threaded).</text>
  </g>
</svg>
