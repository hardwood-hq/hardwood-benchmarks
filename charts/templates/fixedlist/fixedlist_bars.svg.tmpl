<svg xmlns="http://www.w3.org/2000/svg" width="780" height="546" viewBox="0 0 780 546" font-family="-apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif">
  <rect width="780" height="546" fill="#ffffff"/>

  <!-- Title -->
  <text x="40" y="30" font-size="20" font-weight="700" fill="#1a1a1a">$title</text>
  <text x="40" y="50" font-size="12.5" fill="#495057">$subtitle</text>
  <text x="40" y="67" font-size="11" fill="#868e96">$subline</text>

  <!-- Legend -->
  <rect x="40"  y="82" width="12" height="12" rx="2" fill="#a5d8ff"/>
  <rect x="55"  y="82" width="12" height="12" rx="2" fill="#1971c2"/>
  <text x="72"  y="92" font-size="11.5" fill="#495057">column reader (baseline · fast)</text>
  <rect x="270" y="82" width="12" height="12" rx="2" fill="#fab005"/>
  <rect x="285" y="82" width="12" height="12" rx="2" fill="#f08c00"/>
  <text x="302" y="92" font-size="11.5" fill="#495057">row reader (baseline · fast)</text>
  <line x1="490" y1="88" x2="516" y2="88" stroke="#2f9e44" stroke-width="1.6" stroke-dasharray="5 3"/>
  <text x="521" y="92" font-size="11.5" fill="#495057">flat-column read</text>

  <g transform="translate(0, 16)">
  <!-- Y axis title -->
  <text x="22" y="250" font-size="12.5" fill="#495057" transform="rotate(-90 22 250)" text-anchor="middle">throughput (M float32 values/s · higher is better)</text>

  <!-- Gridlines + y ticks (data-driven) -->
  <g stroke="#ececec" stroke-width="1">
    $gridlines
  </g>
  <g font-size="11" fill="#adb5bd" text-anchor="end">
    $ticklabels
  </g>
  <line x1="70" y1="400" x2="740" y2="400" stroke="#bbb" stroke-width="1.5"/>

  <!-- Bars + per-width / per-reader labels (data-driven) -->
  $bars

  <!-- Flat-column read: a plain float32 column of the same values, no list structure -->
  <line x1="70" y1="$floor_y" x2="740" y2="$floor_y" stroke="#2f9e44" stroke-width="1.6" stroke-dasharray="5 3"/>
  <text x="74" y="$floor_y" dy="-5" font-size="11.5" font-weight="700" fill="#2f9e44" text-anchor="start">flat-column read  $floor_v</text>

  <!-- footnote (two lines; first line sits 44px below the reader labels, matching the flat chart) -->
  <text x="40" y="502" font-size="11" fill="#868e96">Dashed line = a plain float32 column read of the same values — no list structure.</text>
  <text x="40" y="518" font-size="11" fill="#868e96">All bars decode identical values. × = fast vs. baseline speedup.</text>
  </g>
</svg>
