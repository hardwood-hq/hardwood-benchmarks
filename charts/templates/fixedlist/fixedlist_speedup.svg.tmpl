<svg xmlns="http://www.w3.org/2000/svg" width="780" height="516" viewBox="0 0 780 516" font-family="-apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif">
  <rect width="780" height="516" fill="#ffffff"/>

  <!-- Title -->
  <text x="40" y="30" font-size="20" font-weight="700" fill="#1a1a1a">Fixed-size-list fast path — speedup over reconstruction</text>
  <text x="40" y="50" font-size="12.5" fill="#495057">Full scan of a LIST&lt;float32&gt; column · $headline</text>
  <text x="40" y="67" font-size="11" fill="#868e96">$ds</text>

  <!-- Legend -->
  <rect x="40"  y="82" width="12" height="12" rx="2" fill="#1971c2"/>
  <text x="57"  y="92" font-size="11.5" fill="#495057">column reader</text>
  <rect x="180" y="82" width="12" height="12" rx="2" fill="#f08c00"/>
  <text x="197" y="92" font-size="11.5" fill="#495057">row reader</text>
  <line x1="320" y1="88" x2="344" y2="88" stroke="#adb5bd" stroke-width="1.5" stroke-dasharray="4 3"/>
  <text x="349" y="92" font-size="11.5" fill="#495057">1x (no speedup)</text>

  <g transform="translate(0, 16)">
  <!-- Y axis title -->
  <text x="22" y="250" font-size="12.5" fill="#495057" transform="rotate(-90 22 250)" text-anchor="middle">speedup (fast ÷ baseline · higher is better)</text>

  <!-- scalar-verified band (k = 9..15, rows not byte-aligned) -->
  <rect x="$notch_x" y="100" width="$notch_w" height="300" fill="#f1f3f5"/>
  <text x="$notch_lx" y="118" font-size="10" fill="#adb5bd" text-anchor="middle">scalar-verified</text>
  <text x="$notch_lx" y="130" font-size="10" fill="#adb5bd" text-anchor="middle">k=9–15</text>

  <!-- Gridlines + y ticks (data-driven) -->
  <g stroke="#ececec" stroke-width="1">
    $gridlines
  </g>
  <g font-size="11" fill="#adb5bd" text-anchor="end">
    $ticklabels
  </g>
  <line x1="70" y1="400" x2="740" y2="400" stroke="#bbb" stroke-width="1.5"/>

  <!-- 1x baseline -->
  <line x1="70" y1="$baseline_y" x2="740" y2="$baseline_y" stroke="#adb5bd" stroke-width="1.3" stroke-dasharray="4 3"/>

  <!-- x ticks (k, log-spaced) -->
  <g font-size="10.5" fill="#adb5bd" text-anchor="middle">
    $xlabels
  </g>
  <text x="405" y="438" font-size="12" fill="#495057" text-anchor="middle">vector length k (elements per row, log scale)</text>

  <!-- Column reader speedup -->
  <polyline points="$col_line" fill="none" stroke="#1971c2" stroke-width="2.2"/>
  <g>
    $col_dots
  </g>

  <!-- Row reader speedup -->
  <polyline points="$row_line" fill="none" stroke="#f08c00" stroke-width="2.2"/>
  <g>
    $row_dots
  </g>

  <!-- footnote -->
  <text x="40" y="486" font-size="11" fill="#868e96">Speedup = reconstruction-baseline time ÷ fast-path time, same file, warm cache. Values are identical between the two (gate-checked).</text>
  </g>
</svg>
